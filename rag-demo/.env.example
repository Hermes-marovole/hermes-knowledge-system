# RAG Demo Configuration
# Copy this file to .env and fill in your values

# OpenAI API Key (optional - only if using OpenAI embeddings or LLM)
OPENAI_API_KEY=your_openai_api_key_here

# Embedding Model Configuration
# Options: "bge-m3" (local, free), "text-embedding-3-small" (openai, low cost)
EMBEDDING_MODEL=bge-m3

# LLM Configuration
# Options: "gpt-3.5-turbo" (requires OPENAI_API_KEY), "local" (placeholder)
LLM_MODEL=gpt-3.5-turbo

# Vector Database Configuration
CHROMA_DB_PATH=./data/chroma_db
COLLECTION_NAME=hermes_knowledge

# Retrieval Configuration
TOP_K=5
BM25_WEIGHT=0.3
SEMANTIC_WEIGHT=0.7

# Chunking Configuration
CHUNK_SIZE=512
CHUNK_OVERLAP=50

# API Configuration (for web interface)
API_HOST=127.0.0.1
API_PORT=8000
